set idearefactormode=keep
set number relativenumber
set ideajoin
set surround
set easymotion
set commentary


let mapleader = " "
nmap <S-Enter> O<Esc>
nmap <CR> o<Esc>
nnoremap <C-j> :m +1<CR>
nnoremap <C-k> :m -2<CR>
inoremap <C-j> <Esc>:m +1<CR>gi
inoremap <C-k> <Esc>:m -2<CR>gi
" ThePrimeagen-style keybindings
" Paste without affecting register (visual mode)
xmap <leader>P "_dP

" Move selected lines up and down (visual mode)
vnoremap J :m '>+1<CR>gv=gv
vnoremap K :m '<-2<CR>gv=gv

" system clipboard
" changed from "+ to "* in version 2.5.0
vmap <leader>y "*y
nmap <leader>y "*yy
nmap <leader>Y "*Y
nmap <leader>p "*p
vmap <leader>p "*p

" Delete to black hole register
nnoremap <leader>d "_d
vnoremap <leader>d "_d

" Keep cursor centered when scrolling
nnoremap <C-d> <C-d>zz
nnoremap <C-u> <C-u>zz

" Keep search terms in the middle
nnoremap n nzzzv
nnoremap N Nzzzv

" Replace word under cursor
nnoremap <leader>s :%s/\<<C-r><C-w>\>/<C-r><C-w>/gI<Left><Left><Left>
" actions
nnoremap gn :action GotoNextOccurrence<CR>
nmap <leader>z :action ToggleDistractionFreeMode<CR>
nnoremap gp :action GotoPreviousOccurrence<CR>
nmap <S-h> <action>(PreviousTab)
nmap <S-l> <action>(NextTab)
nmap <leader>x <action>(CloseEditor)
nmap <leader>i <action>(Generate)
nmap <leader>m <action>(Git.Menu)
nmap <leader>/ <action>(ShowErrorDescription)
nmap <leader>e <action>(GotoNextError)
nmap <leader>f <action>(GotoFile)
nmap <leader>j <action>(ActivateTerminalToolWindow)
nmap <leader>w <action>(SaveFile)
nmap <leader>v <action>(SplitVertically)
nmap <leader>l <action>(Goto Next Splitter)
nmap <leader>h <action>(Goto Previous Splitter)
nmap <leader>c <action>(CommentByLineComment)
nmap <leader>ge <action>(OpenCommitEditor)
nmap gb <action>(AddSelectionForNextOccurrence)
nnoremap <leader><leader> <C-Tab>
set NERDTree
let g:NERDTreeMapActivateNode='l'
let g:NERDTreeMapJumpParent='h'
